# OpenClaw Gateway
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_STATE_DIR=./openclaw-state
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_BIND=lan
GATEWAY_PORT=18789

# Telegram (from Botfather: https://t.me/botfather)
TELEGRAM_BOT_TOKEN=

# Optional: Mission Control dashboard (set ENABLE_MISSION_CONTROL=1 to use)
ENABLE_MISSION_CONTROL=0
AUTH_MODE=local
LOCAL_AUTH_TOKEN=
NEXT_PUBLIC_API_URL=auto
POSTGRES_DB=mission_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
BACKEND_PORT=8000
FRONTEND_PORT=3000
